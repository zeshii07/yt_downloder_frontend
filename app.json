{
  "expo": {
    "name": "Video Downloader",
    "slug": "YouTubeDownloaderApp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080810"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Video Downloader needs access to save videos to your gallery.",
        "NSPhotoLibraryAddUsageDescription": "Video Downloader needs permission to add videos to your gallery."
      }
    },
    "android": {
      "package": "com.zeeshan.videodownloader",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080810"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "bc19a37d-f9c1-4b98-88e4-658730d3e986"
      }
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Video Downloader to access your photos.",
          "savePhotosPermission": "Allow Video Downloader to save videos to your gallery.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ]
  }
}