{
  "expo": {
    "name": "Video Downloader",
    "slug": "video-downloader",
    "version": "1.0.0",
    "orientation": "portrait",
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Video Downloader to access your photos.",
          "savePhotosPermission": "Allow Video Downloader to save videos to your gallery."
        }
      ],
      [
        "expo-file-system",
        {
          "filesystemAllowEscalation": true
        }
      ]
    ],
    "android": {
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_AUDIO"
      ],
      "package": "com.zeeshan.videodownloader",
      "adaptiveIcon": {
        "backgroundColor": "#080910"
      }
    },
    "ios": {
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "Allow Video Downloader to save videos to your gallery."
      }
    }
  }
}